MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=ekap
MONGODB_COLLECTION=ihale_detaylari
GENERATE_PDF=true
PDF_OUTPUT_DIR=reports/pdfs
# Bos birakirsan sistemde uygun Unicode font otomatik secilir.
# PDF_FONT_PATH=/System/Library/Fonts/Supplemental/Arial Unicode.ttf
PDF_FONT_PATH=
STORE_FULL_ILAN_CONTENT=false

PAGE_SIZE=10
MAX_PAGES=0
START_SKIP=0

REQUEST_TIMEOUT_MS=30000
RETRY_COUNT=5
RETRY_DELAY_MS=1500
RATE_LIMIT_MS=300
DETAIL_CONCURRENCY=4
WRITE_BATCH_SIZE=100
SCRAPE_INCREMENTAL=true
SCRAPE_INCREMENTAL_STOP_STREAK=40
SCRAPE_INCREMENTAL_CHECKPOINT=.cache/scrape-incremental.json
SCRAPE_ADAPTIVE_PAGINATION=true
SCRAPE_PAGE_SIZE_MIN=10
SCRAPE_PAGE_SIZE_MAX=40
SCRAPE_PAGE_SIZE_STEP=5
SCRAPE_PAGE_TARGET_MS=1200
SCRAPE_ADAPTIVE_DETAIL_CONCURRENCY=true
DETAIL_CONCURRENCY_MIN=1
DETAIL_CONCURRENCY_MAX=16
DETAIL_PAGE_TARGET_MS=8000
SCRAPE_CONDITIONAL_REQUESTS=true
SCRAPE_CONDITIONAL_CACHE_TTL_MS=21600000
SCRAPE_CONDITIONAL_CACHE_SIZE=2000
SCRAPE_RESPONSE_CACHE_ENABLED=true
SCRAPE_RESPONSE_CACHE_TTL_MS=30000
SCRAPE_RESPONSE_CACHE_SIZE=2000
SCRAPE_CIRCUIT_BREAKER_ENABLED=true
SCRAPE_CIRCUIT_BREAKER_THRESHOLD=3
SCRAPE_CIRCUIT_BREAKER_COOLDOWN_MS=15000
SCRAPE_CIRCUIT_BREAKER_HALF_OPEN_PAGES=1
HTTP_KEEP_ALIVE=true
HTTP_MAX_SOCKETS=32
HTTP_MAX_FREE_SOCKETS=8
HTTP_KEEP_ALIVE_MS=1000

STORE_RAW_HTML=true
DRY_RUN=false
WEB_PORT=8787
WEB_HOST=127.0.0.1

# Web auth (opsiyonel)
AUTH_ENABLED=false
AUTH_COOKIE_NAME=ekap_auth
AUTH_COOKIE_SECURE=false
AUTH_TRUST_PROXY=false
AUTH_SESSION_TTL_MS=28800000
AUTH_LOGIN_WINDOW_MS=900000
AUTH_LOGIN_MAX_ATTEMPTS=8
# password formati: plain:<sifre> veya sha256:<hex>
AUTH_USERS=[{"username":"admin","password":"plain:degistir","role":"admin"}]
AUDIT_LOG_COLLECTION=audit_logs
OPS_ALERT_COLLECTION=ops_alert_events
OPS_BENCHMARK_COLLECTION=ops_benchmark_runs
OPS_DASHBOARD_WINDOW_HOURS=24
OPS_ALERT_EVALUATE_INTERVAL_MS=60000
OPS_ALERT_DOWNLOAD_FAILURE_RATE_PCT=18
OPS_ALERT_SCRAPE_LIST_P95_MS=7000
OPS_ALERT_SCRAPE_DETAIL_P95_MS=15000
OPS_ALERT_SCRAPE_QUEUE_P95=50
OPS_ALERT_STALLED_RUN_MINUTES=20

# EKAP v3 preflight endpoint kontrolu
EKAP_V3_PREFLIGHT_CHECK_ENDPOINT=true
EKAP_V3_PREFLIGHT_STRICT=false
EKAP_V3_PREFLIGHT_ENDPOINT_METHOD=HEAD

# EKAP v3 indirme hiz/tuning varsayilanlari
EKAP_V3_WORKER_COUNT=3
EKAP_V3_WORKER_COUNT_MAX=8
EKAP_V3_JOB_CHUNK_SIZE=2
EKAP_V3_JOB_CHUNK_SIZE_MAX=8
EKAP_V3_TIMEOUT_RETRIES=1
EKAP_V3_RETRY_BASE_DELAY_MS=450
EKAP_V3_RETRY_MAX_DELAY_MS=8000
EKAP_V3_RETRY_JITTER_RATIO=0.2
EKAP_V3_DATE_SHARD_ENABLED=true
EKAP_V3_DATE_SHARD_DAYS=7
EKAP_V3_DATE_SHARD_MIN_SPAN_DAYS=14
EKAP_V3_DATE_SHARD_MAX_PARALLEL=4

# EKAP v3 Playwright indirme davranisi
FAST_MODE=false
COMPUTE_SHA256=true
CONTEXT_RESET_HARD_FACTOR=3
CHECKPOINT_FLUSH_EVERY=8
CHECKPOINT_FLUSH_INTERVAL_MS=1500
BLOCK_RESOURCES=true
AUTO_TUNE=true
# AUTO_TUNE_FILE=/absolute/path/ekap-v3-autotune.json
# RUN_TAG=manual-run-tag
API_FIRST_LIST=true
API_FIRST_LIST_STRICT=false
API_FIRST_DOWNLOAD=true
API_FIRST_STRICT=false

# Ops benchmark script (opsiyonel)
# OPS_BENCHMARK_COOKIE=ekap_auth=...
# OPS_BENCHMARK_USERNAME=admin
# OPS_BENCHMARK_PASSWORD=degistir

# Opsiyonel: endpoint override
# EKAP_LIST_URL=https://ekapv2.kik.gov.tr/b_ihalearama/api/Ihale/GetListByParameters
# EKAP_DETAIL_URL=https://ekapv2.kik.gov.tr/b_ihalearama/api/IhaleDetay/GetByIhaleIdIhaleDetay
