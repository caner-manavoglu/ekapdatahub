MONGODB_URI=mongodb://127.0.0.1:27018
MONGODB_DB=ekap_dev
MONGODB_COLLECTION=ihale_detaylari
GENERATE_PDF=true
PDF_OUTPUT_DIR=reports/pdfs-dev
# Bos birakirsan sistemde uygun Unicode font otomatik secilir.
# PDF_FONT_PATH=/System/Library/Fonts/Supplemental/Arial Unicode.ttf
PDF_FONT_PATH=
STORE_FULL_ILAN_CONTENT=false

PAGE_SIZE=10
MAX_PAGES=0
START_SKIP=0

REQUEST_TIMEOUT_MS=30000
RETRY_COUNT=5
RETRY_DELAY_MS=1500
RATE_LIMIT_MS=300

STORE_RAW_HTML=true
DRY_RUN=false
WEB_PORT=8788
WEB_HOST=127.0.0.1

# Web auth
AUTH_ENABLED=true
AUTH_COOKIE_NAME=ekap_auth_dev
AUTH_COOKIE_SECURE=false
AUTH_TRUST_PROXY=false
AUTH_SESSION_TTL_MS=28800000
AUTH_LOGIN_WINDOW_MS=900000
AUTH_LOGIN_MAX_ATTEMPTS=8
# password formati: plain:<sifre> veya sha256:<hex>
AUTH_USERS=[{"username":"admin","password":"plain:admin","role":"admin"}]
AUDIT_LOG_COLLECTION=audit_logs_dev
EKAP_V3_LOG_COLLECTION=ekap_v3_download_logs_dev

# Geliştirme esnasinda dosya yoneticisi otomatik acilmasin
WEB_SKIP_OPEN_DIR=true

# Opsiyonel: endpoint override
# EKAP_LIST_URL=https://ekapv2.kik.gov.tr/b_ihalearama/api/Ihale/GetListByParameters
# EKAP_DETAIL_URL=https://ekapv2.kik.gov.tr/b_ihalearama/api/IhaleDetay/GetByIhaleIdIhaleDetay
