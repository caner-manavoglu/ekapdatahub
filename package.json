{
  "name": "ekap-mongodb-scraper",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "start": "node src/index.js",
    "start:dry": "DRY_RUN=true GENERATE_PDF=false node src/index.js",
    "web": "node src/web/server.js",
